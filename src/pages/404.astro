---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section style="text-align:center;padding:6rem 2rem;">
    <h1 style="font-size:6rem;margin-bottom:0;color:var(--accent);">404</h1>
    <p style="font-size:1.25rem;color:var(--text-secondary);margin-bottom:2rem;">This page doesn't exist — maybe it went up in smoke.</p>
    <a href="/" class="nav-retailers-cta" style="text-decoration:none;font-size:0.85rem;padding:0.6rem 1.5rem;">
      Back to Home
    </a>
  </section>
</Layout>
